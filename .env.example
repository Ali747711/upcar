# Server
PORT=4000
NODE_ENV=development

# CORS: comma-separated allowed origins, or * for any (dev only)
CORS_ORIGIN=http://localhost:5173

# Database (MongoDB Atlas or local)
MONGODB_URI=mongodb://127.0.0.1:27017/jq-bro
MONGODB_URI=mongodb+srv://jasurupcar_db_user:2myIDotHGgwwuuXn@upcar.nxor4bh.mongodb.net/?appName=upcar

# Auth (JWT). Use a long random string for JWT_SECRET in production.
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# Limits / pagination
MAX_PARTS=500
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Currency formatting
CURRENCY=USD
CURRENCY_LOCALE=en-US

# Cloudinary image hosting (optional — uploads disabled if unset)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=jq-bro/parts
MAX_UPLOAD_BYTES=8388608
